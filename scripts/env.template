# =============================================================================
# Keycloak Export Environment Configuration - Staging
# =============================================================================
# This file contains the Keycloak configuration for a staging environment
# Used by the keycloak-export.sh script for deployment preparation
# =============================================================================

# Keycloak Server Configuration
KEYCLOAK_URL=https://secure.example.com
KEYCLOAK_REALM=ExampleRealm
KEYCLOAK_ADMIN_REALM=ExampleRealm

# Admin Client Configuration (for API access)
KEYCLOAK_ADMIN_CLIENT_ID=actual-admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=your-admin-client-secret

# Application Client Configuration
KEYCLOAK_CLIENT_ID=demo-example
KEYCLOAK_CLIENT_SECRET=your-main-app-client-secret
KEYCLOAK_REDIRECT_URI=http://localhost:3010/auth/keycloak/callback

# OIDC Partner Clients
STALWART_CLIENT_ID=YourStalwartClientId
STALWART_CLIENT_SECRET=your-stalwart-client-secret
SOGO_CLIENT_ID=YourSOGoClientId
SOGO_CLIENT_SECRET=your-sogo-client-secret

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Replace all "your-*-secret" values with actual secrets from Keycloak
# 2. This file should be stored securely and not committed to version control
# 3. Use different credentials for staging vs production
# 4. Rotate secrets regularly
# =============================================================================
